{
  "name": "ambev-automation-e2e",
  "version": "1.0.0",
  "description": "Automação E2E e API com Cypress para Serverest - Prova Técnica Ambev",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test": "cypress run",
    "test:e2e": "cypress run --spec 'cypress/e2e/frontend/**/*.cy.js'",
    "test:api": "cypress run --spec 'cypress/e2e/api/**/*.cy.js'",
    "test:headed": "cypress run --headed --browser chrome"
  },
  "keywords": [
    "cypress",
    "e2e",
    "api",
    "automation",
    "serverest",
    "qa"
  ],
  "author": "Matheus",
  "license": "MIT",
  "devDependencies": {
    "cypress": "^13.17.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
